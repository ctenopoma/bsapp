# ─── API server ───────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080

# ─── Azure AD / Entra ID (leave blank when using DEV_AUTH_BYPASS) ─────────────
VITE_AZURE_TENANT_ID=
VITE_AZURE_CLIENT_ID=

# ─── Dev auth bypass (must match server-side DEV_AUTH_BYPASS=true) ────────────
VITE_DEV_AUTH_BYPASS=true
