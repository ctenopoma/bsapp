# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://bsapp:bsapp@localhost:5432/bsapp?ssl=disable

# ─── Azure AD / Entra ID (leave blank to use DEV_AUTH_BYPASS) ────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=

# ─── Dev mode (skip JWT validation, auto-login as DEV_USER_EMAIL) ─────────────
DEV_AUTH_BYPASS=true
DEV_USER_EMAIL=dev@example.com
DEV_USER_NAME=Dev User

# ─── Extra CORS origins (comma-separated) ────────────────────────────────────
# CORS_ORIGINS=https://myapp.example.com

# ─── LLM ─────────────────────────────────────────────────────────────────────
LLM_IP=127.0.0.1
LLM_PORT=11434
LLM_MODEL=llama3
LLM_API_KEY=dummy
LLM_TEMPERATURE=0.7

# ─── Embedding ───────────────────────────────────────────────────────────────
EMBEDDING_IP=127.0.0.1
EMBEDDING_PORT=11434
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_API_KEY=dummy
VECTOR_SIZE=768

# ─── Rerank ───────────────────────────────────────────────────────────────────
RERANK_IP=127.0.0.1
RERANK_PORT=11434
RERANK_MODEL=reranker
RERANK_API_KEY=dummy

# ─── Qdrant ──────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
